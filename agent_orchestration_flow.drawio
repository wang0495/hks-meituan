        <mxCell id="P4_label" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#1a1a2e;" value="Phase 4: 质量审查循环（Fan-in → Review ↔ Rework，最多2轮）" vertex="1">
          <mxGeometry height="25" width="520" x="40" y="1270" as="geometry" />
        </mxCell>
        <mxCell id="fanin" parent="1" style="text;html=1;fontSize=11;align=center;fillColor=none;strokeColor=#d6b656;fontColor=#d6b656;strokeWidth=1;" value="&lt;b&gt;Wave2 Fan-in → review&lt;/b&gt;" vertex="1">
          <mxGeometry height="25" width="250" x="100" y="1300" as="geometry" />
        </mxCell>
        <mxCell id="review" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#333;fontSize=13;arcSize=20;shadow=1;" value="&lt;b&gt;review&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;质量审查 + _review_router条件边&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="210" x="100" y="1340" as="geometry" />
        </mxCell>
        <mxCell id="review_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" value="&lt;div style=&quot;font-size:10px;text-align:left;line-height:1.5&quot;&gt;&lt;b&gt;审查逻辑 + 条件路由:&lt;/b&gt;&lt;br/&gt;1. 按 scene_type 分化检查规则:&lt;br/&gt;   美食型 → 餐饮子类型多样性&lt;br/&gt;   特种兵型 → 景点覆盖数(5-8个)&lt;br/&gt;   休闲型 → 节奏舒缓度(3-4个)&lt;br/&gt;   目的地型 → POI集中在目的地周围&lt;br/&gt;2. LLM审查 → issues[] + approved&lt;br/&gt;3. &lt;b&gt;_review_router (条件边函数)&lt;/b&gt;:&lt;br/&gt;   approved=true 或 review_round&gt;2 → synthesizer&lt;br/&gt;   approved=false → rework&lt;/div&gt;" vertex="1">
