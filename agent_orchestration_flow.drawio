        <mxCell id="fb2" edge="1" parent="1" source="wave2_dispatcher" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d79b00;strokeWidth=1.5;dashed=1;" target="hotel_expert">
          <mxGeometry relative="1" as="geometry" />
