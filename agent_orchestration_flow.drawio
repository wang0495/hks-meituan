        <mxCell id="dialogue_loop" edge="1" parent="1" source="fb_out2" target="user_feedback" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#6c8ebf;strokeWidth=1.5;dashed=1;fontSize=8;fontColor=#6c8ebf;" value="可继续调整(最多10轮)">
