<mxfile host="Electron" agent="Claude Code">
  <diagram name="Agent Orchestration &amp; Clustering" id="agent-orchestration">
    <mxGraphModel dx="3632" dy="1318" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" value="&lt;div style=&quot;font-size:20px;font-weight:bold;color:#1a1a2e&quot;&gt;CityFlow — MoE Agent 编排 &amp; 集群架构流程图&lt;/div&gt;" vertex="1">
          <mxGeometry height="35" width="600" x="300" y="10" as="geometry" />
        </mxCell>
        <mxCell id="P0_label" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#1a1a2e;" value="Phase 0: 请求入口" vertex="1">
          <mxGeometry height="25" width="200" x="40" y="55" as="geometry" />
        </mxCell>
        <mxCell id="user_input" parent="1" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;size=15;" value="&lt;b&gt;用户输入&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;color:#666&quot;&gt;例: &quot;周末带娃珠海一日游&quot;&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="200" x="80" y="90" as="geometry" />
        </mxCell>
        <mxCell id="P1_label" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#1a1a2e;" value="Phase 1: 意图解析 &amp; 候选加载" vertex="1">
          <mxGeometry height="25" width="300" x="40" y="165" as="geometry" />
        </mxCell>
        <mxCell id="rule_guard" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=13;arcSize=20;shadow=1;" value="&lt;b&gt;rule_guard&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;规则守卫 — 入口节点&lt;/font&gt;" vertex="1">
          <mxGeometry height="55" width="200" x="80" y="200" as="geometry" />
        </mxCell>
        <mxCell id="rg_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" value="&lt;div style=&quot;text-align:left;font-size:10px;line-height:1.5&quot;&gt;&lt;b&gt;5步流程:&lt;/b&gt;&lt;br/&gt;1. &lt;b&gt;parse_intent&lt;/b&gt; — LLM解析自然语言→结构化意图&lt;br/&gt;   输出: city, pace, group, budget, preferred_categories&lt;br/&gt;2. &lt;b&gt;fetch_pois&lt;/b&gt; — 美团API加载全量POI(降级→本地JSON)&lt;br/&gt;3. &lt;b&gt;filter_candidates&lt;/b&gt; — 硬约束预筛(时间/预算/距离)&lt;br/&gt;4. &lt;b&gt;_ensure_key_pois_llm&lt;/b&gt; — LLM确保核心景点入池&lt;br/&gt;5. &lt;b&gt;_check_hard_rules&lt;/b&gt; — 元规则防火墙&lt;br/&gt;&lt;br/&gt;&lt;b&gt;输出 →&lt;/b&gt; user_intent, candidates, rule_violations&lt;/div&gt;" vertex="1">
          <mxGeometry height="150" width="280" x="310" y="180" as="geometry" />
        </mxCell>
        <mxCell id="e01" edge="1" parent="1" source="user_input" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=2;" target="rule_guard">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="P2_label" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#1a1a2e;" value="Phase 2: MoE 专家路由（LLM场景分类 + 动态权重）" vertex="1">
          <mxGeometry height="25" width="450" x="40" y="360" as="geometry" />
        </mxCell>
        <mxCell id="expert_router" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#333;fontSize=13;arcSize=20;shadow=1;" value="&lt;b&gt;expert_router&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;MoE 路由器 — LLM分类&lt;/font&gt;" vertex="1">
          <mxGeometry height="55" width="200" x="80" y="400" as="geometry" />
        </mxCell>
        <mxCell id="er_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" value="&lt;div style=&quot;text-align:left;font-size:10px;line-height:1.5&quot;&gt;&lt;b&gt;LLM分类流程:&lt;/b&gt;&lt;br/&gt;1. &lt;b&gt;_llm_decide&lt;/b&gt; → 返回JSON:&lt;br/&gt;   scene_type: 美食型/观光型/特种兵型/休闲型/目的地型&lt;br/&gt;   expert_weights: {poi:0.8, food:0.6, hotel:0.3, ...}&lt;br/&gt;   active_experts: [权重≥0.3的专家列表]&lt;br/&gt;2. &lt;b&gt;_normalize_scene_type&lt;/b&gt; — 标准化场景类型&lt;br/&gt;3. 权重归一化: poi权重下限0.3，永远激活&lt;br/&gt;4. &lt;b&gt;_compute_pools&lt;/b&gt; — 按专家类型切分候选池&lt;br/&gt;&lt;br/&gt;&lt;b&gt;降级:&lt;/b&gt; LLM失败→_fallback_result规则兜底&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="280" x="310" y="380" as="geometry" />
        </mxCell>
        <mxCell id="e12" edge="1" parent="1" source="rule_guard" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=2;" target="expert_router">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="P3_label" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#1a1a2e;" value="Phase 3: 两波分派 Fan-out（Wave1数据独立 → Wave2依赖Wave1）" vertex="1">
          <mxGeometry height="25" width="520" x="40" y="570" as="geometry" />
        </mxCell>
