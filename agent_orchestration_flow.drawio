        <mxCell id="local_expert" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontColor=#333;arcSize=15;" value="&lt;b&gt;local_expert&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:8px&quot;&gt;本地达人&lt;br/&gt;评分≥4.0精选&lt;/font&gt;" vertex="1">
