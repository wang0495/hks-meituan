        <mxCell id="budget_hacker" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontColor=#333;arcSize=15;" value="&lt;b&gt;budget_hacker&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:8px&quot;&gt;省钱达人&lt;br/&gt;均价≤50/免费景点&lt;/font&gt;" vertex="1">
