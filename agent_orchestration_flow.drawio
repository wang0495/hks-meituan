        <mxCell id="P4_label" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#1a1a2e;" value="Phase 4: 质量审查循环（Fan-in → Review ↔ Rework，最多2轮）" vertex="1">
          <mxGeometry height="25" width="520" x="40" y="1270" as="geometry" />
        </mxCell>
        <mxCell id="fanin" parent="1" style="text;html=1;fontSize=11;align=center;fillColor=none;strokeColor=#d6b656;fontColor=#d6b656;strokeWidth=1;" value="&lt;b&gt;Wave2 Fan-in → review&lt;/b&gt;" vertex="1">
          <mxGeometry height="25" width="250" x="100" y="1300" as="geometry" />
        </mxCell>
        <mxCell id="review" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#333;fontSize=13;arcSize=20;shadow=1;" value="&lt;b&gt;review&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;质量审查&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="170" x="120" y="1340" as="geometry" />
        </mxCell>
        <mxCell id="review_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" value="&lt;div style=&quot;font-size:10px;text-align:left;line-height:1.5&quot;&gt;&lt;b&gt;审查逻辑:&lt;/b&gt;&lt;br/&gt;1. 按 scene_type 分化检查规则:&lt;br/&gt;   美食型 → 餐饮子类型多样性&lt;br/&gt;   特种兵型 → 景点覆盖数(5-8个)&lt;br/&gt;   休闲型 → 节奏舒缓度(3-4个)&lt;br/&gt;   目的地型 → POI集中在目的地周围&lt;br/&gt;2. LLM审查 → issues[] + approved&lt;br/&gt;3. approved=true → synthesizer&lt;br/&gt;4. approved=false → rework&lt;br/&gt;5. review_round &gt; 2 → 强制通过&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="250" x="350" y="1340" as="geometry" />
        </mxCell>
        <mxCell id="decision" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontColor=#333;" value="&lt;b&gt;通过?&lt;/b&gt;" vertex="1">
          <mxGeometry height="60" width="90" x="160" y="1420" as="geometry" />
        </mxCell>
        <mxCell id="rework" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#333;fontSize=13;arcSize=20;" value="&lt;b&gt;rework&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;按反馈重选&lt;/font&gt;" vertex="1">
          <mxGeometry height="45" width="120" x="30" y="1440" as="geometry" />
        </mxCell>
        <mxCell id="rework_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=10;fillColor=#ffe6e6;strokeColor=#b85450;fontSize=9;align=left;spacingLeft=6;" value="&lt;div style=&quot;font-size:9px;text-align:left;line-height:1.4&quot;&gt;&lt;b&gt;rework 逻辑:&lt;/b&gt;&lt;br/&gt;1. 收集有问题的agent名(bad_agents)&lt;br/&gt;2. 移除这些agent的旧proposals&lt;br/&gt;3. _rework_poi / _rework_food / _rework_generic:&lt;br/&gt;   LLM从candidates重选，避开旧提案&lt;br/&gt;   覆盖所有8种expert类型&lt;br/&gt;4. 合并 kept_proposals + new_proposals&lt;br/&gt;5. 清空 review_feedback&lt;br/&gt;6. review_round + 1&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="200" x="30" y="1500" as="geometry" />
        </mxCell>
        <mxCell id="fi1" edge="1" parent="1" source="traffic_expert" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d79b00;strokeWidth=1.5;" target="review">
