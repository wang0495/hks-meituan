        </mxCell>
        <mxCell id="wave2_dispatcher" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontColor=#333;shadow=1;" value="&lt;b&gt;_wave2_dispatcher&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;LangGraph Send()&lt;br/&gt;Wave2: Traffic/Hotel/Local/Budget&lt;/font&gt;" vertex="1">
