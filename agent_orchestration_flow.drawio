        </mxCell>
        <mxCell id="pool_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=10;fillColor=#e6f2ff;strokeColor=#4a90d9;fontSize=9;align=left;spacingLeft=6;" value="&lt;div style=&quot;font-size:9px;text-align:left;line-height:1.4&quot;&gt;&lt;b&gt;_compute_pools 候选池切分逻辑:&lt;/b&gt;&lt;br/&gt;━━━━━━━━━━━━━━━━━━━━━━━━&lt;br/&gt;poi: 排除餐饮类别+澳门+无评分&lt;br/&gt;food: _is_food_poi() 综合判定&lt;br/&gt;hotel: _HOTEL_CATS 白名单匹配&lt;br/&gt;traffic: Top15 高评分POI&lt;br/&gt;weather: 全量候选(不做筛选)&lt;br/&gt;local: 评分 ≥ 4.0 的高分POI&lt;br/&gt;destination: 用户提及城市+5km半径&lt;br/&gt;budget: 均价≤50 或 免费类别&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="210" x="655" y="895" as="geometry" />
        </mxCell>
        <mxCell id="wave1_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#82b366;strokeWidth=2;dashed=1;arcSize=10;fontSize=10;fontColor=#82b366;" value="&lt;b&gt;Wave1 (数据独立)&lt;/b&gt;" vertex="1">
          <mxGeometry height="75" width="610" x="20" y="700" as="geometry" />
