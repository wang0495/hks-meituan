        <mxCell id="fb_intent_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=8;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=7;align=left;spacingLeft=5;" value="&lt;div style=&quot;font-size:7px;text-align:left;line-height:1.3&quot;&gt;&lt;b&gt;feedback_router (统一入口):&lt;/b&gt;&lt;br/&gt;LLM 一刀切分类，不分关键词/fallback:&lt;br/&gt;1. 理解反馈 → 判断走A还是B&lt;br/&gt;   A: &quot;换掉渔女&quot; → 结构化操作&lt;br/&gt;   B: &quot;想多看海边&quot; → 重入原graph&lt;br/&gt;2. 走B时:&lt;br/&gt;   - 组装 prev_round_context&lt;br/&gt;   - 标记 rerun_experts（受影响的）&lt;br/&gt;   - 缓存未受影响expert的上轮提案&lt;br/&gt;   - Command(goto=&quot;expert_router&quot;)&lt;br/&gt;3. expert_router 检测 rerun_experts&lt;br/&gt;   只重跑标记的，其余注入缓存提案&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="160" x="1610" y="1020" as="geometry" />
        </mxCell>
