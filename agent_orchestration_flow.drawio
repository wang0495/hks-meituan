        <mxCell id="synthesizer" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#333;fontSize=14;arcSize=20;shadow=1;" value="&lt;b&gt;synthesizer&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;MoE 路线组装器&lt;/font&gt;" vertex="1">
          <mxGeometry height="55" width="200" x="660" y="95" as="geometry" />
        </mxCell>
        <mxCell id="synth_pipeline" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#f0e6ff;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=8;" value="&lt;div style=&quot;font-size:10px;text-align:left;line-height:1.5&quot;&gt;&lt;b&gt;组装流水线 (8步):&lt;/b&gt;&lt;br/&gt;━━━━━━━━━━━━━━━━━━━&lt;br/&gt;① proposals 按agent类型分类:&lt;br/&gt;   POI: poi/budget_hacker/destination/local&lt;br/&gt;   FOOD: food/food_expert&lt;br/&gt;   HOTEL: hotel/hotel_expert&lt;br/&gt;   TRAFFIC: traffic/traffic_expert&lt;br/&gt;② 过滤澳门POI (_is_likely_macau)&lt;br/&gt;③ 美食场景: poi_proposals最多保留2个&lt;br/&gt;④ &lt;b&gt;SYNTHESIZER_MODE 选择组装架构&lt;/b&gt;&lt;br/&gt;⑤ _cap_route_stops 站数上限&lt;br/&gt;⑥ _ensure_food_in_route 补餐饮&lt;br/&gt;⑦ _ensure_poi_in_route 补景点&lt;br/&gt;⑧ generate_narrative 文案生成&lt;/div&gt;" vertex="1">
          <mxGeometry height="210" width="240" x="1110" y="100" as="geometry" />
        </mxCell>
        <mxCell id="e_dec_synth" edge="1" parent="1" source="decision" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;fontSize=10;fontColor=#82b366;" target="synthesizer" value="通过">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="205" y="1500" />
              <mxPoint x="600" y="1500" />
              <mxPoint x="600" y="122" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="modes_title" parent="1" style="text;html=1;fontSize=11;align=left;fillColor=none;strokeColor=none;fontColor=#333;" value="&lt;b&gt;SYNTHESIZER_MODE 架构选项（环境变量切换）:&lt;/b&gt;" vertex="1">
          <mxGeometry height="22" width="350" x="660" y="170" as="geometry" />
        </mxCell>
        <mxCell id="m_default" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=9;arcSize=10;" value="&lt;b&gt;default&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:7px&quot;&gt;单次LLM组装&lt;/font&gt;" vertex="1">
          <mxGeometry height="35" width="90" x="660" y="200" as="geometry" />
        </mxCell>
        <mxCell id="m_tournament" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;arcSize=10;" value="&lt;b&gt;tournament&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:7px&quot;&gt;锦标赛(默认)&lt;/font&gt;" vertex="1">
          <mxGeometry height="35" width="90" x="760" y="200" as="geometry" />
        </mxCell>
        <mxCell id="m_best_of_n" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=9;arcSize=10;" value="&lt;b&gt;best_of_n&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:7px&quot;&gt;多候选投票&lt;/font&gt;" vertex="1">
          <mxGeometry height="35" width="90" x="860" y="200" as="geometry" />
        </mxCell>
        <mxCell id="m_geo_cluster" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=9;arcSize=10;" value="&lt;b&gt;geo_cluster&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:7px&quot;&gt;地理聚类+TSP&lt;/font&gt;" vertex="1">
          <mxGeometry height="35" width="100" x="960" y="200" as="geometry" />
        </mxCell>
        <mxCell id="m_self_refine" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=9;arcSize=10;" value="&lt;b&gt;self_refine&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:7px&quot;&gt;自我迭代精炼&lt;/font&gt;" vertex="1">
          <mxGeometry height="35" width="90" x="660" y="245" as="geometry" />
        </mxCell>
        <mxCell id="m_constraint" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=9;arcSize=10;" value="&lt;b&gt;constraint&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:7px&quot;&gt;约束求解&lt;/font&gt;" vertex="1">
          <mxGeometry height="35" width="90" x="760" y="245" as="geometry" />
        </mxCell>
        <mxCell id="m_pts" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=9;arcSize=10;" value="&lt;b&gt;pts&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:7px&quot;&gt;POI-TSP混合&lt;/font&gt;" vertex="1">
          <mxGeometry height="35" width="90" x="860" y="245" as="geometry" />
        </mxCell>
        <mxCell id="m_tournament_geo" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=9;arcSize=10;" value="&lt;b&gt;tournament_geo&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:7px&quot;&gt;锦标赛+地理聚类&lt;/font&gt;" vertex="1">
          <mxGeometry height="35" width="100" x="960" y="245" as="geometry" />
        </mxCell>
        <mxCell id="arch_detail" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#f0e6ff;strokeColor=#9673a6;fontSize=9;align=left;spacingLeft=6;" value="&lt;div style=&quot;font-size:9px;text-align:left;line-height:1.5&quot;&gt;&lt;b&gt;关键架构详解:&lt;/b&gt;&lt;br/&gt;━━━━━━━━━━━━━━━━━━━━━━━━━━&lt;br/&gt;&lt;b&gt;tournament (锦标赛):&lt;/b&gt;&lt;br/&gt;  生成N条候选路线 → 硬约束验证 →&lt;br/&gt;  多数投票选最优签名 → 返回胜出路线&lt;br/&gt;&lt;br/&gt;&lt;b&gt;geo_cluster (地理聚类):&lt;/b&gt;&lt;br/&gt;  _geo_cluster_proposals(8km半径) →&lt;br/&gt;  LLM从聚类选代表 → 时间窗校验 →&lt;br/&gt;  2-opt TSP局部优化 → _dedup去重&lt;br/&gt;&lt;br/&gt;&lt;b&gt;best_of_n (多候选投票):&lt;/b&gt;&lt;br/&gt;  生成N条候选 → _verify硬约束 →&lt;br/&gt;  多数投票按POI名称集选最优&lt;br/&gt;&lt;br/&gt;&lt;b&gt;self_refine (自我精炼):&lt;/b&gt;&lt;br/&gt;  初始组装 → LLM自我审查 →&lt;br/&gt;  迭代修正(最多3轮) → 输出精炼路线&lt;/div&gt;" vertex="1">
          <mxGeometry height="245" width="250" x="660" y="295" as="geometry" />
        </mxCell>
        <mxCell id="post_process" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=10;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;align=left;spacingLeft=6;" value="&lt;div style=&quot;font-size:9px;text-align:left;line-height:1.4&quot;&gt;&lt;b&gt;后处理流水线:&lt;/b&gt;&lt;br/&gt;━━━━━━━━━━━━━━━━━━━&lt;br/&gt;1. route为None → _fallback_assemble&lt;br/&gt;2. _cap_route_stops:&lt;br/&gt;   观光6站/美食4站/特种兵8站/休闲4站&lt;br/&gt;   亲子/退休再减1站&lt;br/&gt;3. _ensure_food_in_route: 补餐饮&lt;br/&gt;4. _ensure_poi_in_route: 补景点&lt;br/&gt;5. _ensure_min_food_in_route: 最少餐饮数&lt;br/&gt;6. generate_narrative: LLM文案生成&lt;br/&gt;   (失败→_build_fallback_narrative)&lt;/div&gt;" vertex="1">
          <mxGeometry height="150" width="210" x="960" y="350" as="geometry" />
        </mxCell>
        <mxCell id="P6_label" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#1a1a2e;" value="Phase 6: 动态行程呈现（热力图 + 决策溯源）" vertex="1">
          <mxGeometry height="25" width="400" x="610" y="545" as="geometry" />
        </mxCell>
        <mxCell id="live_itinerary" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#333;fontSize=13;arcSize=20;shadow=1;" value="&lt;b&gt;live_itinerary&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;动态行程构建&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="200" x="660" y="610" as="geometry" />
        </mxCell>
        <mxCell id="live_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" value="&lt;div style=&quot;font-size:10px;text-align:left;line-height:1.5&quot;&gt;&lt;b&gt;输出内容:&lt;/b&gt;&lt;br/&gt;━━━━━━━━━━━━━━━━━━━&lt;br/&gt;&lt;b&gt;1. build_heatmap 置信度热力图&lt;/b&gt;&lt;br/&gt;   green(&gt;0.8): 多方验证，高置信&lt;br/&gt;   yellow(0.5-0.8): 有备选/风险&lt;br/&gt;   red(&lt;0.5): 需用户决策&lt;br/&gt;   冲突agent的confidence × 0.7&lt;br/&gt;&lt;br/&gt;&lt;b&gt;2. build_decision_trace 决策溯源&lt;/b&gt;&lt;br/&gt;   每个POI: why(推理) + agent来源&lt;br/&gt;   + confidence + name&lt;br/&gt;&lt;br/&gt;&lt;b&gt;3. heatmap_summary 热力图摘要&lt;/b&gt;&lt;br/&gt;   score = (green + yellow×0.6 + red×0.2) / total&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="240" x="930" y="560" as="geometry" />
        </mxCell>
        <mxCell id="end_node" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=13;fontColor=#333;shadow=1;" value="&lt;b&gt;END&lt;/b&gt;" vertex="1">
          <mxGeometry height="40" width="80" x="720" y="690" as="geometry" />
        </mxCell>
        <mxCell id="e_synth_live" edge="1" parent="1" source="synthesizer" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=2;" target="live_itinerary">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_live_end" edge="1" parent="1" source="live_itinerary" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=2;" target="end_node">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="state_flow" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#f0f0f0;strokeColor=#999;fontSize=10;align=left;spacingLeft=8;fontColor=#333;" value="&lt;div style=&quot;font-size:10px;text-align:left;line-height:1.5&quot;&gt;&lt;b&gt;TravelState 数据流总览:&lt;/b&gt;&lt;br/&gt;━━━━━━━━━━━━━━━━━━━━━━━━━━&lt;br/&gt;user_input&lt;br/&gt;  → user_intent + candidates + rule_violations&lt;br/&gt;  → scene_type + expert_weights + active_experts&lt;br/&gt;  → expert_candidates (按专家切分的候选池)&lt;br/&gt;  → Wave1 proposals (4专家并行)&lt;br/&gt;  → wave2_fanin (原样传递)&lt;br/&gt;  → Wave2 proposals (4专家并行)&lt;br/&gt;  → review_feedback → reworked_proposals&lt;br/&gt;  → route + narrative&lt;br/&gt;  → heatmap + decision_trace&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="280" x="850" y="1050" as="geometry" />
        </mxCell>
        <mxCell id="emergence" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;fontColor=#333;arcSize=15;dashed=1;" value="&lt;b&gt;emergence_check&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:8px&quot;&gt;涌现式校验(辅助节点)&lt;/font&gt;" vertex="1">
          <mxGeometry height="45" width="160" x="30" y="570" as="geometry" />
        </mxCell>
        <mxCell id="emergence_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=8;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=8;align=left;spacingLeft=5;" value="&lt;div style=&quot;font-size:8px;text-align:left;line-height:1.3&quot;&gt;&lt;b&gt;矛盾检测(独立于主流程):&lt;/b&gt;&lt;br/&gt;detect_conflicts: 地理/预算/时间/主题&lt;br/&gt;resolve_conflicts: 自动解决&lt;br/&gt;should_escalate: 是否需用户决策&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="180" x="30" y="620" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
