        <mxCell id="e_simple_loop" edge="1" parent="1" source="d_simple_out" target="user_feedback" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=1;entryY=0;entryDx=0;entryDy=0;strokeColor=#82b366;strokeWidth=1;dashed=1;fontSize=7;fontColor=#82b366;" value="继续">
