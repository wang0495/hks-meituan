        <mxCell id="fa7" edge="1" parent="1" source="dispatcher" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=1.5;dashed=1;" target="destination_expert">
          <mxGeometry relative="1" as="geometry" />
