<mxfile host="Electron" agent="Claude Code">
  <diagram name="Synthesizer 时间分配流程 (LLM版)" id="time-flow">
    <mxGraphModel dx="635" dy="412" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" value="&lt;div style=&quot;font-size:18px;font-weight:bold;color:#1a1a2e&quot;&gt;_build_route_from_llm_order() 时间分配流程 (LLM版)&lt;/div&gt;" vertex="1">
          <mxGeometry height="35" width="500" x="200" y="10" as="geometry" />
        </mxCell>
        <mxCell id="input" parent="1" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;size=15;" value="&lt;b&gt;输入&lt;/b&gt;&lt;br/&gt;ordered_stops: [{name, type}]&lt;br/&gt;proposals: poi/food/hotel&lt;br/&gt;intent: time/pace/budget" vertex="1">
          <mxGeometry height="70" width="250" x="50" y="60" as="geometry" />
        </mxCell>
        <mxCell id="s1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;fontColor=#333;arcSize=15;" value="&lt;b&gt;1. 构建 name_map&lt;/b&gt;&lt;br/&gt;poi + food + hotel proposals&lt;br/&gt;→ {name: content} 映射" vertex="1">
          <mxGeometry height="50" width="200" x="75" y="160" as="geometry" />
        </mxCell>
        <mxCell id="s2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;fontColor=#333;arcSize=15;" value="&lt;b&gt;2. 读取时间参数&lt;/b&gt;&lt;br/&gt;start_time (默认09:00)&lt;br/&gt;end_time (默认21:00)" vertex="1">
          <mxGeometry height="50" width="200" x="75" y="230" as="geometry" />
        </mxCell>
        <mxCell id="s3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;fontColor=#333;arcSize=15;" value="&lt;b&gt;3. 节奏参数&lt;/b&gt;&lt;br/&gt;特种兵: stay×0.7, travel=10&lt;br/&gt;平衡: stay×1.0, travel=15&lt;br/&gt;慢游: stay×1.3, travel=20" vertex="1">
          <mxGeometry height="60" width="200" x="75" y="300" as="geometry" />
        </mxCell>
        <mxCell id="loop_start" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontColor=#333;" value="&lt;b&gt;遍历 ordered_stops&lt;/b&gt;" vertex="1">
          <mxGeometry height="60" width="150" x="100" y="390" as="geometry" />
        </mxCell>
        <mxCell id="s4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;fontColor=#333;arcSize=10;" value="&lt;b&gt;4. 模糊匹配 name&lt;/b&gt;&lt;br/&gt;精确 → 包含 → 去括号&lt;br/&gt;找不到则 skip" vertex="1">
          <mxGeometry height="50" width="150" x="300" y="390" as="geometry" />
        </mxCell>
        <mxCell id="s5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;fontColor=#333;arcSize=10;" value="&lt;b&gt;5. 去重检查&lt;/b&gt;&lt;br/&gt;canonical_name&lt;br/&gt;已用则 skip" vertex="1">
          <mxGeometry height="50" width="130" x="480" y="390" as="geometry" />
        </mxCell>
        <mxCell id="s_llm_branch" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontColor=#333;fontStyle=1;" value="&lt;b&gt;LLM 时间分配&lt;/b&gt;&lt;br/&gt;_llm_allocate_times()" vertex="1">
          <mxGeometry height="70" width="160" x="560" y="610" as="geometry" />
        </mxCell>
        <mxCell id="s_llm_ok" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontColor=#333;arcSize=10;" value="&lt;b&gt;✓ LLM 成功&lt;/b&gt;&lt;br/&gt;返回每个站的:&lt;br/&gt;arrival / departure / stay_min&lt;br/&gt;&lt;br/&gt;LLM 已考虑:&lt;br/&gt;• 午餐 11:30-13:00&lt;br/&gt;• 晚餐 17:30-19:00&lt;br/&gt;• POI类型定时长&lt;br/&gt;• 市区/跨区交通" vertex="1">
          <mxGeometry height="100" width="160" x="870" y="290" as="geometry" />
        </mxCell>
        <mxCell id="s_llm_fail" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6e6;strokeColor=#cc0000;fontSize=9;fontColor=#cc0000;arcSize=10;" value="&lt;b&gt;✗ LLM 失败&lt;/b&gt;&lt;br/&gt;降级到纯算法兜底" vertex="1">
          <mxGeometry height="50" width="140" x="870" y="430" as="geometry" />
        </mxCell>
        <mxCell id="s_algo_fallback" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontColor=#333;arcSize=10;" value="&lt;b&gt;⚠ 纯算法兜底&lt;/b&gt;&lt;br/&gt;_algo_allocate_times()&lt;br/&gt;原有逻辑: 90min×multiplier&lt;br/&gt;dist×8min clamp(5,60)&lt;br/&gt;机械累加" vertex="1">
          <mxGeometry height="70" width="160" x="1060" y="420" as="geometry" />
        </mxCell>
        <mxCell id="loop_end" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontColor=#333;arcSize=15;" value="&lt;b&gt;循环结束&lt;/b&gt;&lt;br/&gt;生成 steps[]" vertex="1">
          <mxGeometry height="40" width="120" x="100" y="540" as="geometry" />
        </mxCell>
        <mxCell id="s9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;fontColor=#333;arcSize=15;" value="&lt;b&gt;9. 时间窗过滤&lt;/b&gt;&lt;br/&gt;arrival &gt; end_dt 的站移除" vertex="1">
          <mxGeometry height="40" width="180" x="100" y="610" as="geometry" />
        </mxCell>
        <mxCell id="s10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;fontColor=#333;arcSize=15;" value="&lt;b&gt;10. _dedup_route + _enforce_time_windows&lt;/b&gt;" vertex="1">
          <mxGeometry height="40" width="250" x="100" y="670" as="geometry" />
        </mxCell>
        <mxCell id="output" parent="1" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;size=15;" value="&lt;b&gt;输出&lt;/b&gt;&lt;br/&gt;{route: steps[], total_cost, emotion_curve}" vertex="1">
