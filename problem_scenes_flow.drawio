          <mxGeometry x="60" y="1135" width="240" height="55" as="geometry" />
        </mxCell>

        <!-- Problem note on synth B -->
        <mxCell id="B_synth_issue1" parent="1" style="shape=hexagon;perimeter=hexagonPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontColor=#b85450;size=15;shadow=1;" value="&lt;b&gt;⚠ 问题3 (致命)&lt;/b&gt;&lt;br&gt;LLM不遵守短途约束&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;prompt说&quot;最多3站&quot;&lt;br&gt;LLM仍选5-7站&lt;br&gt;短途检测在prompt里&lt;br&gt;但LLM经常无视&lt;/font&gt;" vertex="1">
          <mxGeometry x="340" y="1125" width="170" height="80" as="geometry" />
        </mxCell>

        <mxCell id="B_synth_issue2" parent="1" style="shape=hexagon;perimeter=hexagonPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontColor=#b85450;size=15;shadow=1;" value="&lt;b&gt;⚠ 问题4&lt;/b&gt;&lt;br&gt;_llm_fix_times 倒序&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;#86夜景18:00开始&lt;br&gt;但LLM排17:00先到夜市&lt;br&gt;时间线混乱倒序&lt;/font&gt;" vertex="1">
          <mxGeometry x="340" y="1215" width="170" height="70" as="geometry" />
