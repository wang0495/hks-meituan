          <mxGeometry x="60" y="1230" width="240" height="45" as="geometry" />
        </mxCell>

        <!-- Problem note on score B -->
        <mxCell id="B_score_issue" parent="1" style="shape=hexagon;perimeter=hexagonPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontColor=#b85450;size=15;shadow=1;" value="&lt;b&gt;⚠ 问题5 (评分)&lt;/b&gt;&lt;br&gt;评分不理解短途&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;&quot;2站太少&quot;→F&lt;br&gt;但2小时2站合理!&lt;br&gt;评分标准不区分&lt;br&gt;短途vs全天场景&lt;/font&gt;" vertex="1">
          <mxGeometry x="340" y="1300" width="170" height="75" as="geometry" />
        </mxCell>

        <!-- Output B -->
        <mxCell id="B_output" parent="1" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;size=12;" value="&lt;b&gt;输出: F级路线&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#b85450&quot;&gt;#7: 2小时吃了3家(不合理)&lt;br&gt;#43: 3小时只打了2个点(评分嫌少)&lt;br&gt;#71: 傍晚散步5小时空白&lt;br&gt;#17: 机场美食选了不相关的店&lt;/font&gt;" vertex="1">
          <mxGeometry x="60" y="1310" width="250" height="70" as="geometry" />
        </mxCell>

        <!-- Solution box B -->
        <mxCell id="B_solution" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=12;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;shadow=1;" value="&lt;div style=&quot;font-size:10px;text-align:left;line-height:1.6&quot;&gt;&lt;b&gt;🟢 修复方案:&lt;/b&gt;&lt;br&gt;━━━━━━━━━━━━━━━━━━━&lt;br&gt;&lt;b&gt;S1: intent_parser 强制时间约束&lt;/b&gt;&lt;br&gt;  &quot;2小时&quot;→start=当前, end=start+2h&lt;br&gt;  &quot;傍晚&quot;→start=17:00, end=20:00&lt;br&gt;&lt;br&gt;&lt;b&gt;S2: expert 候选池按时间裁剪&lt;/b&gt;&lt;br&gt;  可用时间&lt;3h → 候选池上限5个&lt;br&gt;  而非默认10-15个&lt;br&gt;&lt;br&gt;&lt;b&gt;S3: synthesizer 硬截断&lt;/b&gt;&lt;br&gt;  短途检测后直接steps[:max]&lt;br&gt;  不走LLM组装(避免LLM无视)&lt;br&gt;&lt;br&gt;&lt;b&gt;S4: 评分标准区分短途&lt;/b&gt;&lt;br&gt;  时间&lt;3h时, 完整性满分=2站&lt;br&gt;  不按全天3-8站标准评判&lt;/div&gt;" vertex="1">
          <mxGeometry x="560" y="770" width="260" height="310" as="geometry" />
        </mxCell>

