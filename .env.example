# ═══════════════════════════════════════════════════════════
# CityFlow 环境变量配置模板
# 复制为 .env 并填入实际值: cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ---- 运行模式 ----
ENVIRONMENT=dev           # dev / test / prod
DEBUG=true                # dev默认true, prod自动false
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=INFO            # DEBUG/INFO/WARNING/ERROR
LOG_FILE=                 # 留空=stdout, 或指定文件路径

# ---- 数据 ----
DATA_DIR=./backend/data
CACHE_TTL=300
USE_DB=false              # true=PostgreSQL优先, false=JSON文件

# ---- LLM 配置 (主模型) ----
# 替换为你的 LLM 服务商 API 地址和密钥
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=10
LLM_MAX_RETRIES=3

# ---- LLM 配置 (Expert模型) ----
# 可选：独立配置 Expert 模型，留空则回退到主模型配置
EXPERT_LLM_API_KEY=
EXPERT_LLM_BASE_URL=
EXPERT_LLM_MODEL=

# ---- LLM 配置 (Intent解析, 可独立配置) ----
INTENT_LLM_BASE_URL=
INTENT_LLM_API_KEY=
INTENT_LLM_MODEL=

# ---- Synthesizer配置 ----
SYNTHESIZER_MODE=tournament  # tournament / simple

# ---- 数据库 (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=cityflow
DB_PASSWORD=
DB_DATABASE=cityflow

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- 安全配置 ----
SECURITY_API_KEY=          # 留空=不启用认证(dev模式)
SECURITY_ENCRYPTION_KEY=   # 必填! 数据加密主密钥
SECURITY_RATE_LIMIT_PER_MINUTE=60
SECURITY_MAX_REQUEST_SIZE=10485760
SECURITY_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]
SECURITY_TRUSTED_PROXIES=[]  # 可信代理IP, 如 ["10.0.0.1"]

# ---- 搜索 API ----
SEARCH_API_URL=https://uapis.cn/api/v1/search/aggregate
SEARCH_API_KEY=
SEARCH_TIMEOUT=12

# ---- Agent配置 ----
AGENT_ENABLED=false
AGENT_VALIDATION_TIMEOUT=10.0
AGENT_MAX_VALIDATION_ROUNDS=2
AGENT_LOCAL_EXPERT_TEMPERATURE=0.3

# ---- 监控 ----
SENTRY_DSN=                # 留空=禁用Sentry
APP_VERSION=1.0.0
INSTANCE_ID=               # 多实例部署时唯一标识

# ---- 加密 ----
ENCRYPTION_KEY=            # 等同于SECURITY_ENCRYPTION_KEY
ENCRYPTION_KEY_FILE=       # 从文件读取密钥(优先于ENCRYPTION_KEY)
