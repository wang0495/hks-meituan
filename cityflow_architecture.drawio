        <mxCell id="exp_hotel" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;arcSize=12;" value="🏨 &lt;b&gt;Hotel&lt;/b&gt;&lt;br&gt;住宿推荐&lt;br&gt;&lt;i&gt;过夜激活&lt;/i&gt;" vertex="1">
          <mxGeometry height="55" width="110" x="345" y="1248" as="geometry" />
        </mxCell>
        <mxCell id="exp_traffic" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;arcSize=12;" value="🚗 &lt;b&gt;Traffic&lt;/b&gt;&lt;br&gt;交通规划&lt;br&gt;&lt;i&gt;&gt;4个POI激活&lt;/i&gt;" vertex="1">
          <mxGeometry height="55" width="110" x="470" y="1248" as="geometry" />
        </mxCell>
        <mxCell id="exp_weather" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;arcSize=12;" value="🌤 &lt;b&gt;Weather&lt;/b&gt;&lt;br&gt;天气分析&lt;br&gt;&lt;i&gt;户外激活&lt;/i&gt;" vertex="1">
          <mxGeometry height="55" width="110" x="595" y="1248" as="geometry" />
        </mxCell>
        <mxCell id="exp_local" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;arcSize=12;" value="🗺 &lt;b&gt;Local&lt;/b&gt;&lt;br&gt;本地向导&lt;br&gt;&lt;i&gt;独特体验激活&lt;/i&gt;" vertex="1">
          <mxGeometry height="55" width="110" x="720" y="1248" as="geometry" />
        </mxCell>
        <mxCell id="exp_dest" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;arcSize=12;" value="🎯 &lt;b&gt;Destination&lt;/b&gt;&lt;br&gt;目的地专家&lt;br&gt;&lt;i&gt;目的地型激活&lt;/i&gt;" vertex="1">
          <mxGeometry height="55" width="110" x="845" y="1248" as="geometry" />
        </mxCell>
        <mxCell id="exp_budget" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;arcSize=12;" value="💰 &lt;b&gt;Budget&lt;/b&gt;&lt;br&gt;省钱优化&lt;br&gt;&lt;i&gt;预算&lt;200激活&lt;/i&gt;" vertex="1">
          <mxGeometry height="55" width="110" x="970" y="1248" as="geometry" />
        </mxCell>
        <mxCell id="e_router_experts" edge="1" parent="1" source="expert_router" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#4dd8e8;fontSize=10;fontStyle=1;" target="experts_box" value="Send 动态fan-out">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="review" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;arcSize=10;spacingLeft=8;" value="&lt;b style=&#39;font-size:13px&#39;&gt;🔍 Review&lt;/b&gt;&lt;br&gt;&lt;i&gt;nodes/review.py:17&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;做什么:&lt;/b&gt;&lt;br&gt;1. 按scene_type选择检查规则&lt;br&gt;   (美食型→检查餐饮多样性,&lt;br&gt;    目的地型→检查核心目的地,&lt;br&gt;    特种兵型→检查地标覆盖数...)&lt;br&gt;2. _llm_review() LLM审查提案&lt;br&gt;3. 生成review_feedback&lt;br&gt;&lt;br&gt;&lt;b&gt;防死循环:&lt;/b&gt; round&gt;2 强制通过&lt;br&gt;&lt;b&gt;输出:&lt;/b&gt; review_feedback + review_round" vertex="1">
          <mxGeometry height="200" width="280" x="10" y="1430" as="geometry" />
        </mxCell>
        <mxCell id="e_experts_review" edge="1" parent="1" source="experts_box" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#d6b656;" target="review">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rework" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;arcSize=10;spacingLeft=8;" value="&lt;b style=&quot;font-size:13px&quot;&gt;🔄 Rework&lt;/b&gt;&lt;br&gt;&lt;i&gt;nodes/review.py:137&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;做什么:（&lt;font style=&quot;color: rgb(255, 51, 51);&quot;&gt;可能存在问题 为什么只重选景点和餐饮 其余的呢？&lt;/font&gt;）&lt;/b&gt;&lt;br&gt;1. 删除有问题agent的旧proposals&lt;br&gt;2. _rework_poi() LLM重选景点&lt;br&gt;3. _rework_food() LLM重选餐饮&lt;br&gt;4. 合并: kept + reworked proposals&lt;br&gt;&lt;br&gt;&lt;b&gt;输出:&lt;/b&gt;&lt;br&gt;reworked_proposals (覆盖原proposals)" vertex="1">
          <mxGeometry height="170" width="270" x="435" y="1380" as="geometry" />
        </mxCell>
        <mxCell id="e_review_rework" edge="1" parent="1" source="review" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#b85450;fontSize=11;fontStyle=1;fontColor=#b85450;" target="rework" value="&lt;b&gt;不通过&lt;/b&gt; (有issues)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_rework_review" edge="1" parent="1" source="rework" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#b85450;fontSize=10;fontColor=#b85450;curved=1;" target="review" value="二次检查">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="545" y="1340" />
              <mxPoint x="220" y="1340" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="synthesizer" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;arcSize=10;spacingLeft=8;" value="&lt;b style=&quot;font-size:13px&quot;&gt;✨ Synthesizer&lt;/b&gt;&lt;br&gt;&lt;i&gt;nodes/synthesizer.py&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;组装模式 (SYNTHESIZER_MODE):（这个里面有曾经测试的许多的模式 经过所有测试下来 tournament为最佳实践）&lt;/b&gt;&lt;br&gt;• tournament (默认) — 并行策略锦标赛&lt;br&gt;• best_of_n — 多候选投票取最优&lt;br&gt;• geo_cluster — 地理聚类+TSP排序&lt;br&gt;• self_refine — 维度导向自精炼&lt;br&gt;• constraint — 迭代约束满足&lt;br&gt;• pts — Google PTS LLM选点+算法排序&lt;br&gt;&lt;br&gt;&lt;b&gt;核心流程:&lt;/b&gt;&lt;br&gt;1. _cap_route_stops() 截断站点数&lt;br&gt;2. _ensure_food_in_route() 保餐饮&lt;br&gt;3. _ensure_poi_in_route() 保景点&lt;br&gt;4. _enforce_time_windows() 时间窗约束&lt;br&gt;5. _dedup_route() 去重&lt;br&gt;6. LLM编排路线顺序+时间分配" vertex="1">
          <mxGeometry height="260" width="300" x="730" y="1350" as="geometry" />
        </mxCell>
