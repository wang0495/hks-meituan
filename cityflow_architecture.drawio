            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="pref_subtitle" parent="1" style="text;html=1;fontSize=11;fontColor=#999;align=left;verticalAlign=top;" value="需要 user_id 才会激活" vertex="1">
          <mxGeometry height="20" width="200" x="950" y="435" as="geometry" />
        </mxCell>
        <mxCell id="pref_manager" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;arcSize=10;spacingLeft=5;" value="&lt;b style=&#39;font-size:12px&#39;&gt;PreferenceManager&lt;/b&gt;&lt;br&gt;&lt;i&gt;preference_manager.py&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;做什么:&lt;/b&gt;&lt;br&gt;1. from_user_id() 识别用户身份&lt;br&gt;2. LTM.predict_preferences() 长期记忆预测&lt;br&gt;3. PerceptionService.get_context() 上下文感知&lt;br&gt;   (天气/温度/时段/星期/季节)&lt;br&gt;4. WeightMapper.compute_solver_weights()&lt;br&gt;   计算动态权重&lt;br&gt;&lt;br&gt;&lt;b&gt;输出:&lt;/b&gt;&lt;br&gt;dynamic_weights + 融合后的 user_intent" vertex="1">
          <mxGeometry height="210" width="290" x="955" y="460" as="geometry" />
        </mxCell>
        <mxCell id="ltm" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;" value="&lt;b&gt;🧠 LTM&lt;/b&gt;&lt;br&gt;长期记忆&lt;br&gt;&lt;i&gt;memory/long_term.py&lt;/i&gt;&lt;br&gt;&lt;br&gt;• trip_history 只append&lt;br&gt;• 趋势实时计算&lt;br&gt;• 渐进学习权重" vertex="1">
          <mxGeometry height="90" width="160" x="1340" y="455" as="geometry" />
        </mxCell>
        <mxCell id="e_pref_ltm" edge="1" parent="1" source="pref_manager" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#7b6cf6;" target="ltm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_phase1_pref" edge="1" parent="1" source="profile_internal" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#7b6cf6;" target="pref_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="phase2_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#51aef9;strokeWidth=3;arcSize=3;" value="" vertex="1">
          <mxGeometry height="600" width="1320" x="20" y="760" as="geometry" />
        </mxCell>
        <mxCell id="phase2_title" parent="1" style="text;html=1;fontSize=17;fontStyle=1;fontColor=#51aef9;align=left;verticalAlign=top;" value="Phase 2: MoE 多Agent分布式规划 (agents_v3)" vertex="1">
          <mxGeometry height="25" width="500" x="70" y="735" as="geometry" />
        </mxCell>
        <mxCell id="rule_guard" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;arcSize=10;spacingLeft=8;" value="&lt;b style=&#39;font-size:13px&#39;&gt;🧠 Rule Guard&lt;/b&gt;&lt;br&gt;&lt;i&gt;nodes/rule_guard.py:37&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;做什么:&lt;/b&gt;&lt;br&gt;1. parse_intent(user_input) 意图解析&lt;br&gt;2. fetch_pois() 加载美团API POI&lt;br&gt;   → 降级: get_data() 本地JSON&lt;br&gt;3. _fix_food_categories() 修正误分类&lt;br&gt;   (美食街category=文化 → 餐饮)&lt;br&gt;4. filter_candidates() 宽松预筛&lt;br&gt;   (半径/时间窗/预算/情绪匹配)&lt;br&gt;5. _ensure_key_pois_llm() LLM补核心景点&lt;br&gt;   (如&quot;带孩子去长隆&quot;不能被预算过滤掉)&lt;br&gt;6. check_hard_rules() 元规则防火墙&lt;br&gt;&lt;br&gt;&lt;b&gt;输出:&lt;/b&gt;&lt;br&gt;user_intent + candidates + rule_violations" vertex="1">
          <mxGeometry height="280" width="300" x="80" y="775" as="geometry" />
        </mxCell>
        <mxCell id="expert_router" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;arcSize=10;spacingLeft=8;" value="&lt;b style=&#39;font-size:13px&#39;&gt;📡 Expert Router&lt;/b&gt;&lt;br&gt;&lt;i&gt;nodes/expert_router.py:284&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;做什么:&lt;/b&gt;&lt;br&gt;1. _rule_precheck() 规则预检&lt;br&gt;   (无歧义场景省LLM调用)&lt;br&gt;2. _llm_decide() DeepSeek分类场景&lt;br&gt;   → 5种: 观光/美食/目的地/特种兵/休闲&lt;br&gt;3. 计算 expert_weights 专家权重&lt;br&gt;4. _compute_pools() 按专家分候选池&lt;br&gt;   (poi/food/hotel/traffic/weather/&lt;br&gt;    local/destination/budget_hacker)&lt;br&gt;5. 动态 Send fan-out 到活跃专家&lt;br&gt;&lt;br&gt;&lt;b&gt;输出:&lt;/b&gt;&lt;br&gt;scene_type + expert_weights + active_experts" vertex="1">
          <mxGeometry height="280" width="300" x="430" y="775" as="geometry" />
        </mxCell>
        <mxCell id="e_guard_router" edge="1" parent="1" source="rule_guard" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#51aef9;" target="expert_router">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="experts_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f8ff;strokeColor=#4dd8e8;strokeWidth=2;arcSize=5;" value="" vertex="1">
          <mxGeometry height="100" width="1290" x="95" y="1223" as="geometry" />
        </mxCell>
        <mxCell id="experts_title" parent="1" style="text;html=1;fontSize=12;fontStyle=1;fontColor=#4dd8e8;align=left;verticalAlign=top;" value="专家集群 (按需激活, 并行执行, 共享 base.py LLM客户端池)（&lt;font style=&quot;color: rgb(255, 51, 51);&quot;&gt;这里有些智能体不应该并行 有些可以并行 有些需要优化&lt;/font&gt;）" vertex="1">
          <mxGeometry height="20" width="500" x="90" y="1223" as="geometry" />
        </mxCell>
