        <mxCell id="middleware_chain" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=10;dashed=1;arcSize=8;" value="&lt;b&gt;中间件链&lt;/b&gt; (从外到内)&lt;br&gt;CORS → APIKey → Shutdown → Prometheus → RateLimit&lt;br&gt;→ InputValidation → Security → Session → APIVersion → Config" vertex="1">
