          <mxGeometry height="25" width="250" x="950" y="415" as="geometry" />
        </mxCell>
        <mxCell id="xig67QonhW9qwMeS7Yfu-7" edge="1" parent="1" source="pref_subtitle" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="pref_manager" value="">
