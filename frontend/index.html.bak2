<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CityFlow · 智能出行规划</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════════════════
   Design System — CityFlow Dark
   ═══════════════════════════════════════════════════════════════ */
:root {
  --bg: #0a0e17;
  --bg-card: rgba(15, 20, 35, 0.85);
  --bg-glass: rgba(20, 28, 50, 0.72);
  --bg-hover: rgba(30, 40, 70, 0.6);
  --text: #e8ecf4;
  --text-dim: #8892a8;
  --text-muted: #5a6478;
  --accent: #4facfe;
  --accent2: #00f2fe;
  --coral: #ff6b6b;
  --green: #51cf66;
  --gold: #ffd43b;
  --purple: #b197fc;
  --border: rgba(255,255,255,0.06);
  --border-accent: rgba(79,172,254,0.3);
  --shadow: 0 8px 32px rgba(0,0,0,0.4);
  --radius: 16px;
  --radius-sm: 10px;
  --font: 'Inter', 'Noto Sans SC', -apple-system, sans-serif;
  --ease: cubic-bezier(0.22, 0.61, 0.36, 1);
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: var(--font);
  background: var(--bg);
  color: var(--text);
  font-size: 14px;
  line-height: 1.5;
  height: 100vh;
  overflow: hidden;
  -webkit-font-smoothing: antialiased;
}

/* ═══════════════════════════════════════════════════════════════
   Layout — Map + Panels
   ═══════════════════════════════════════════════════════════════ */
#mapContainer {
  position: fixed;
  inset: 0;
  z-index: 1;
}

.side-panel {
  position: fixed;
  left: 16px; top: 16px; bottom: 16px;
  width: 380px;
  z-index: 10;
  display: flex;
  flex-direction: column;
  gap: 12px;
  pointer-events: none;
}

.panel {
  background: var(--bg-card);
  backdrop-filter: blur(24px) saturate(1.2);
  -webkit-backdrop-filter: blur(24px) saturate(1.2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  pointer-events: auto;
  overflow: hidden;
  transition: all 0.4s var(--ease);
}

.input-panel { padding: 20px; flex-shrink: 0; }

.input-header {
  display: flex; align-items: center; gap: 10px; margin-bottom: 16px;
}
.input-header .logo {
  width: 36px; height: 36px;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px;
  box-shadow: 0 4px 12px rgba(79,172,254,0.3);
}
.input-header h1 {
  font-size: 18px; font-weight: 700;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.input-header .version {
  font-size: 11px; color: var(--text-muted); margin-left: auto;
  padding: 2px 8px; border: 1px solid var(--border); border-radius: 20px;
}

.search-wrap { position: relative; margin-bottom: 12px; }
.search-wrap input {
  width: 100%; padding: 12px 44px 12px 16px;
  background: rgba(255,255,255,0.05); border: 1px solid var(--border);
  border-radius: var(--radius-sm); color: var(--text);
  font-family: var(--font); font-size: 14px; outline: none;
  transition: all 0.3s;
}
.search-wrap input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(79,172,254,0.15);
  background: rgba(255,255,255,0.08);
}
.search-wrap input::placeholder { color: var(--text-muted); }

.search-wrap .send-btn {
  position: absolute; right: 4px; top: 50%; transform: translateY(-50%);
  width: 34px; height: 34px; border-radius: 8px; border: none;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  color: #fff; font-size: 16px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.2s;
}
.search-wrap .send-btn:hover { transform: translateY(-50%) scale(1.05); }
.search-wrap .send-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

.quick-tags { display: flex; flex-wrap: wrap; gap: 6px; }
.quick-tag {
  padding: 5px 12px; border-radius: 20px; border: 1px solid var(--border);
  background: transparent; color: var(--text-dim); font-size: 12px;
  font-family: var(--font); cursor: pointer; transition: all 0.2s; white-space: nowrap;
}
.quick-tag:hover {
  border-color: var(--accent); color: var(--accent);
  background: rgba(79,172,254,0.08);
}

/* Route Panel */
.route-panel { flex: 1; min-height: 0; display: flex; flex-direction: column; }
.route-header {
  padding: 16px 20px 12px; border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;
}
.route-header h2 { font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
.route-header .day-switch { display: flex; gap: 4px; }
.day-btn {
  width: 28px; height: 28px; border-radius: 8px; border: 1px solid var(--border);
  background: transparent; color: var(--text-dim); font-size: 12px;
  font-weight: 600; font-family: var(--font); cursor: pointer; transition: all 0.2s;
}
.day-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; }

.route-steps { flex: 1; overflow-y: auto; padding: 12px; }
.route-steps::-webkit-scrollbar { width: 4px; }
.route-steps::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 4px; }

.step-card {
  display: flex; gap: 12px; padding: 12px; border-radius: var(--radius-sm);
  margin-bottom: 8px; background: rgba(255,255,255,0.02); border: 1px solid transparent;
  cursor: pointer; transition: all 0.25s var(--ease); position: relative;
  animation: stepSlideIn 0.4s var(--ease) backwards;
}
@keyframes stepSlideIn {
  from { opacity: 0; transform: translateX(-20px); }
  to { opacity: 1; transform: translateX(0); }
}
.step-card:hover { background: var(--bg-hover); border-color: var(--border); transform: translateX(4px); }
.step-card.active { background: rgba(79,172,254,0.08); border-color: var(--border-accent); }

.step-num {
  width: 32px; height: 32px; border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  color: #fff; font-size: 13px; font-weight: 700;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  box-shadow: 0 2px 8px rgba(79,172,254,0.3);
}
.step-content { flex: 1; min-width: 0; }
.step-name { font-size: 14px; font-weight: 600; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.step-meta { display: flex; align-items: center; gap: 8px; font-size: 11px; color: var(--text-muted); }
.step-time { color: var(--accent); font-weight: 500; }
.step-narrative {
  font-size: 12px; color: var(--text-dim); margin-top: 4px; line-height: 1.4;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.step-connector { width: 2px; height: 12px; background: linear-gradient(to bottom, var(--accent), transparent); margin-left: 27px; opacity: 0.3; }

/* Agent Pipeline Panel */
.agent-panel { position: fixed; right: 16px; top: 16px; width: 320px; z-index: 10; pointer-events: none; }
.agent-panel .panel { pointer-events: auto; }

.agent-header {
  padding: 16px 20px 12px; border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 8px;
}
.agent-header h2 { font-size: 14px; font-weight: 600; }
.agent-header .status-dot {
  width: 8px; height: 8px; border-radius: 50%; background: var(--text-muted); transition: all 0.3s;
}
.agent-header .status-dot.active {
  background: var(--green); box-shadow: 0 0 8px rgba(81,207,102,0.5); animation: pulse 1.5s infinite;
}
@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }

.agent-body { padding: 16px; }

.arch-diagram { position: relative; height: 280px; margin-bottom: 12px; }
.arch-node {
  position: absolute; padding: 6px 12px; border-radius: 8px;
  background: rgba(255,255,255,0.04); border: 1px solid var(--border);
  font-size: 11px; font-weight: 500; text-align: center;
  transition: all 0.4s var(--ease); cursor: default; white-space: nowrap;
}
.arch-node.active {
  background: rgba(79,172,254,0.15); border-color: var(--accent);
  box-shadow: 0 0 12px rgba(79,172,254,0.2); transform: scale(1.05);
}
.arch-node.done { background: rgba(81,207,102,0.1); border-color: rgba(81,207,102,0.3); }
.arch-node.error { background: rgba(255,107,107,0.1); border-color: rgba(255,107,107,0.3); }

.arch-wave-label {
  position: absolute; left: 0; font-size: 10px; font-weight: 700;
  color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em;
}

.agent-flow { display: flex; flex-direction: column; gap: 6px; }
.agent-step {
  display: flex; align-items: center; gap: 10px; padding: 8px 12px;
  border-radius: 8px; background: rgba(255,255,255,0.02);
  border: 1px solid transparent; transition: all 0.3s;
}
.agent-step.active { background: rgba(79,172,254,0.08); border-color: var(--border-accent); }
.agent-step.done { opacity: 0.6; }
.agent-step .step-icon {
  width: 24px; height: 24px; border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; flex-shrink: 0; background: rgba(255,255,255,0.05); transition: all 0.3s;
}
.agent-step.active .step-icon { background: var(--accent); color: #fff; box-shadow: 0 2px 8px rgba(79,172,254,0.3); }
.agent-step.done .step-icon { background: var(--green); color: #fff; }
.agent-step .step-label { font-size: 12px; font-weight: 500; }
.agent-step .step-status { margin-left: auto; font-size: 11px; color: var(--text-muted); }

/* Chat Panel */
.chat-panel {
  position: fixed; bottom: 16px; left: 50%; transform: translateX(-50%);
  width: min(680px, calc(100vw - 760px)); z-index: 10; pointer-events: none;
}
.chat-panel .panel { pointer-events: auto; }
.chat-messages { max-height: 200px; overflow-y: auto; padding: 16px; }
.chat-messages::-webkit-scrollbar { width: 4px; }
.chat-messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 4px; }
.chat-msg { padding: 10px 14px; border-radius: 12px; margin-bottom: 8px; font-size: 13px; line-height: 1.5; animation: chatFade 0.3s var(--ease); }
@keyframes chatFade { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
.chat-msg.system { background: rgba(79,172,254,0.08); border: 1px solid rgba(79,172,254,0.15); color: var(--text-dim); }
.chat-msg.user { background: rgba(79,172,254,0.15); border: 1px solid rgba(79,172,254,0.2); margin-left: 40px; }
.chat-msg .msg-label { font-size: 10px; font-weight: 600; color: var(--accent); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 4px; }

.emotion-section { padding: 12px 16px; border-top: 1px solid var(--border); }
.emotion-section h3 { font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px; }
#emotionCanvas { width: 100%; height: 60px; border-radius: 8px; }

.loading-overlay {
  position: fixed; inset: 0; z-index: 100;
  background: rgba(10,14,23,0.8); backdrop-filter: blur(8px);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; pointer-events: none; transition: opacity 0.3s;
}
.loading-overlay.active { opacity: 1; pointer-events: auto; }
.loading-spinner {
  width: 48px; height: 48px; border: 3px solid rgba(79,172,254,0.2);
  border-top-color: var(--accent); border-radius: 50%;
  animation: spin 0.8s linear infinite; margin: 0 auto 16px;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 14px; color: var(--text-dim); text-align: center; }

.narrative-section { padding: 12px 16px; border-top: 1px solid var(--border); }
.narrative-section .opening { font-size: 13px; color: var(--text-dim); font-style: italic; line-height: 1.6; }
.narrative-section .closing { font-size: 13px; color: var(--text-dim); margin-top: 8px; line-height: 1.6; }

.stats-bar { display: flex; gap: 12px; padding: 12px 16px; border-top: 1px solid var(--border); flex-shrink: 0; }
.stat-item { flex: 1; text-align: center; }
.stat-value { font-size: 16px; font-weight: 700; color: var(--accent); }
.stat-label { font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; }

.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px 20px; color: var(--text-muted); text-align: center; }
.empty-state .icon { font-size: 48px; margin-bottom: 12px; opacity: 0.5; }
.empty-state p { font-size: 13px; line-height: 1.6; }

.hidden { display: none !important; }
</style>
</head>
<body>

<!-- Map Container -->
<div id="mapContainer"></div>

<!-- Loading Overlay -->
<div class="loading-overlay" id="loadingOverlay">
  <div class="loading-content">
    <div class="loading-spinner"></div>
    <div class="loading-text" id="loadingText">正在规划路线...</div>
  </div>
</div>

<!-- Side Panel -->
<div class="side-panel">
  <div class="panel input-panel">
    <div class="input-header">
      <div class="logo">🗺</div>
      <div><h1>CityFlow</h1></div>
      <span class="version">MoE v3</span>
    </div>
    <div class="search-wrap">
      <input type="text" id="userInput" placeholder="描述你的出行需求..." autocomplete="off">
      <button class="send-btn" id="sendBtn" onclick="submitPlan()">→</button>
    </div>
    <div class="quick-tags">
      <button class="quick-tag" onclick="fillInput('情侣珠海一日游，预算500元')">💑 情侣游</button>
      <button class="quick-tag" onclick="fillInput('带孩子去长隆海洋王国，预算1000元')">👨‍👩‍👧 亲子游</button>
      <button class="quick-tag" onclick="fillInput('珠海美食一日游，想吃海鲜')">🍜 美食</button>
      <button class="quick-tag" onclick="fillInput('一天打卡珠海所有著名景点')">⚡ 特种兵</button>
      <button class="quick-tag" onclick="fillInput('珠海两日游，节奏慢，喜欢公园和海边')">🌿 休闲</button>
    </div>
  </div>

  <div class="panel route-panel" id="routePanel">
    <div class="route-header">
      <h2>📍 路线规划</h2>
      <div class="day-switch" id="daySwitch"></div>
    </div>
    <div class="route-steps" id="routeSteps">
      <div class="empty-state">
        <div class="icon">🗺</div>
        <p>输入你的出行需求<br>AI 智能体将为你规划最佳路线</p>
      </div>
    </div>
    <div class="stats-bar hidden" id="statsBar">
      <div class="stat-item"><div class="stat-value" id="statSteps">0</div><div class="stat-label">站点</div></div>
      <div class="stat-item"><div class="stat-value" id="statTime">0h</div><div class="stat-label">时长</div></div>
      <div class="stat-item"><div class="stat-value" id="statCost">¥0</div><div class="stat-label">预算</div></div>
    </div>
    <div class="narrative-section hidden" id="narrativeSection">
      <div class="opening" id="narrativeOpening"></div>
      <div class="closing" id="narrativeClosing"></div>
    </div>
    <div class="emotion-section hidden" id="emotionSection">
      <h3>情绪曲线</h3>
      <canvas id="emotionCanvas"></canvas>
    </div>
  </div>
</div>

<!-- Agent Pipeline Panel -->
<div class="agent-panel">
  <div class="panel" id="agentPanel">
    <div class="agent-header">
      <div class="status-dot" id="agentStatusDot"></div>
      <h2>🤖 智能体管线</h2>
    </div>
    <div class="agent-body">
      <div class="arch-diagram" id="archDiagram"></div>
      <div class="agent-flow" id="agentFlow"></div>
    </div>
  </div>
</div>

<!-- Chat Panel -->
<div class="chat-panel" id="chatPanel">
  <div class="panel">
    <div class="chat-messages" id="chatMessages"></div>
  </div>
</div>

<!-- L7 3D Map SDK (高德地图) -->
<script src="https://unpkg.com/@antv/l7@2.21.8/dist/l7.js"></script>

<script>
// ═══════════════════════════════════════════════════════════════
// CityFlow Frontend — 主逻辑 (L7 3D Map)
// ═══════════════════════════════════════════════════════════════

const API_BASE = window.location.origin;

// ── 全局状态 ──
const state = {
  scene: null,
  map: null,
  steps: [],
  currentDay: 1,
  totalDays: 1,
  multiRoutes: [],
  routeId: null,
  isPlanning: false,
  routeLayer: null,
  markerLayer: null,
  arrowLayer: null,
};

// ── 快捷输入 ──
function fillInput(text) {
  document.getElementById('userInput').value = text;
  document.getElementById('userInput').focus();
}

// ── L7 3D 地图初始化 ──
async function initMap() {
  const { Scene, GaodeMap, PointLayer, LineLayer } = L7;

  const scene = new Scene({
    id: 'mapContainer',
    map: new GaodeMap({
      center: [113.55, 22.27],
      zoom: 12,
      pitch: 45,
      bearing: -15,
      style: 'amap://styles/dark',
      key: 'e2a4f77a5b16efcf19b88a1e87ab88fd',
      securityJsCode: '8e6d3a6134d4516497913a5e295b5610',
    }),
  });

  await new Promise(resolve => scene.on('loaded', resolve));

  state.scene = scene;
  state.map = scene.map;
  return scene;
}

// ── 路线渲染 (L7 3D) ──
function clearRoute() {
  if (state.routeLayer) { state.scene.removeLayer(state.routeLayer); state.routeLayer = null; }
  if (state.markerLayer) { state.scene.removeLayer(state.markerLayer); state.markerLayer = null; }
  if (state.arrowLayer) { state.scene.removeLayer(state.arrowLayer); state.arrowLayer = null; }
}

function renderRouteOnMap(steps) {
  if (!state.scene || !steps.length) return;
  clearRoute();

  const { PointLayer, LineLayer } = L7;

  const validSteps = steps.filter(s => s.poi && s.poi.lng && s.poi.lat);
  if (validSteps.length < 1) return;

  // ── 虚线路线 + 方向箭头 ──
  const lineFeatures = [];
  for (let i = 0; i < validSteps.length - 1; i++) {
    const from = validSteps[i];
    const to = validSteps[i + 1];
    lineFeatures.push({
      type: 'Feature',
      geometry: {
        type: 'LineString',
        coordinates: [
          [from.poi.lng, from.poi.lat],
          [to.poi.lng, to.poi.lat],
        ],
      },
      properties: {
        index: i,
        from: from.poi.name || '',
        to: to.poi.name || '',
      },
    });
  }

  if (lineFeatures.length > 0) {
    const lineSource = {
      type: 'FeatureCollection',
      features: lineFeatures,
    };

    // 虚线层
    const routeLine = new LineLayer({ zIndex: 2 })
      .source(lineSource)
      .size(2.5)
      .color('#4facfe')
      .style({
        lineType: 'dash',
        dashArray: [8, 4],
        opacity: 0.8,
      });
    state.scene.addLayer(routeLine);
    state.routeLayer = routeLine;

    // 箭头层 (方向指示)
    const arrowLine = new LineLayer({ zIndex: 3 })
      .source(lineSource)
      .size(10)
      .color('#00f2fe')
      .shape('arrow')
      .style({
        opacity: 0.6,
      });
    state.scene.addLayer(arrowLine);
    state.arrowLayer = arrowLine;
  }

  // ── 3D 柱状标记 ──
  const pointFeatures = validSteps.map((step, i) => ({
    type: 'Feature',
    geometry: { type: 'Point', coordinates: [step.poi.lng, step.poi.lat] },
    properties: {
      name: step.poi.name || `站点 ${i + 1}`,
      index: i + 1,
      category: step.poi.category || '',
      time: step.arrival_time || '',
    },
  }));

  const pointSource = {
    type: 'FeatureCollection',
    features: pointFeatures,
  };

  // 3D 柱体
  const markers = new PointLayer({ zIndex: 10 })
    .source(pointSource)
    .shape('cylinder')
    .size('index', [8, 8, 20])
    .color('#4facfe')
    .active(true)
    .style({
      opacity: 0.9,
      sourceColor: '#00f2fe',
      targetColor: '#4facfe',
    });

  markers.on('mousemove', (e) => {
    const props = e.feature.properties;
    new L7.Popup({ offsets: [0, 0] })
      .setLnglat(e.lngLat)
      .setHTML(`<strong>${props.name}</strong><br><small>#${props.index} · ${props.category}</small><br><small>${props.time}</small>`)
      .addTo(state.scene);
  });

  state.scene.addLayer(markers);
  state.markerLayer = markers;

  // 序号标注
  const labelLayer = new PointLayer({ zIndex: 11 })
    .source(pointSource)
    .shape('index', 'text')
    .size(14)
    .color('#fff')
    .style({
      textAnchor: 'center',
      textOffset: [0, -20],
      stroke: '#4facfe',
      strokeWidth: 2,
    });
  state.scene.addLayer(labelLayer);

  // 视角适配
  const bounds = validSteps.reduce(
    (b, s) => {
      b.minLng = Math.min(b.minLng, s.poi.lng);
      b.maxLng = Math.max(b.maxLng, s.poi.lng);
      b.minLat = Math.min(b.minLat, s.poi.lat);
      b.maxLat = Math.max(b.maxLat, s.poi.lat);
      return b;
    },
    { minLng: 180, maxLng: -180, minLat: 90, maxLat: -90 }
  );

  state.map.fitBounds(
    [[bounds.minLng, bounds.minLat], [bounds.maxLng, bounds.maxLat]],
    { padding: 80, maxZoom: 15 }
  );
}

// ── 步骤卡片渲染 ──
function renderSteps(steps, day) {
  const container = document.getElementById('routeSteps');
  if (!steps.length) {
    container.innerHTML = '<div class="empty-state"><div class="icon">🗺</div><p>暂无路线数据</p></div>';
    return;
  }
  container.innerHTML = steps.map((step, i) => {
    const poi = step.poi || {};
    const time = step.arrival_time || '';
    const name = poi.name || `站点 ${i + 1}`;
    const category = poi.category || '';
    const narrative = step.narrative || '';
    return `
      <div class="step-card" style="animation-delay: ${i * 0.08}s" onclick="focusStep(${i})">
        <div class="step-num">${i + 1}</div>
        <div class="step-content">
          <div class="step-name">${escapeHtml(name)}</div>
          <div class="step-meta">
            ${time ? `<span class="step-time">${time}</span>` : ''}
            ${category ? `<span>${escapeHtml(category)}</span>` : ''}
          </div>
          ${narrative ? `<div class="step-narrative">${escapeHtml(narrative)}</div>` : ''}
        </div>
      </div>
      ${i < steps.length - 1 ? '<div class="step-connector"></div>' : ''}
    `;
  }).join('');
}

function focusStep(index) {
  const step = state.steps[index];
  if (step && step.poi && step.poi.lng && step.poi.lat && state.map) {
    state.map.setZoomAndCenter(15, [step.poi.lng, step.poi.lat], true, { duration: 800 });
  }
}

// ── 多日切换 ──
function renderDaySwitch(totalDays, currentDay) {
  const container = document.getElementById('daySwitch');
  if (totalDays <= 1) { container.innerHTML = ''; return; }
  container.innerHTML = Array.from({ length: totalDays }, (_, i) => {
    const day = i + 1;
    return `<button class="day-btn ${day === currentDay ? 'active' : ''}" onclick="switchDay(${day})">${day}</button>`;
  }).join('');
}

function switchDay(day) {
  state.currentDay = day;
  const route = state.multiRoutes[day - 1];
  if (route) {
    const steps = route.route || route.steps || [];
    state.steps = steps;
    renderSteps(steps, day);
    renderRouteOnMap(steps);
    renderDaySwitch(state.totalDays, day);
  }
}

// ── 统计栏 ──
function renderStats(steps) {
  const statsBar = document.getElementById('statsBar');
  if (!steps.length) { statsBar.classList.add('hidden'); return; }
  statsBar.classList.remove('hidden');
  document.getElementById('statSteps').textContent = steps.length;
  const first = steps[0].arrival_time;
  const last = steps[steps.length - 1].departure_time;
  if (first && last) {
    const startMin = parseTime(first);
    const endMin = parseTime(last);
    const hours = ((endMin - startMin) / 60).toFixed(1);
    document.getElementById('statTime').textContent = hours + 'h';
  }
}

function parseTime(str) {
  if (!str) return 0;
  const [h, m] = str.split(':').map(Number);
  return h * 60 + m;
}

// ── 叙事渲染 ──
function renderNarrative(narrative) {
  const section = document.getElementById('narrativeSection');
  if (!narrative) { section.classList.add('hidden'); return; }
  section.classList.remove('hidden');
  document.getElementById('narrativeOpening').textContent = narrative.opening || '';
  document.getElementById('narrativeClosing').textContent = narrative.closing || '';
}

// ── 情绪曲线 ──
function renderEmotionCurve(curve) {
  const section = document.getElementById('emotionSection');
  if (!curve || !curve.length) { section.classList.add('hidden'); return; }
  section.classList.remove('hidden');
  const canvas = document.getElementById('emotionCanvas');
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  canvas.width = canvas.offsetWidth * dpr;
  canvas.height = 60 * dpr;
  ctx.scale(dpr, dpr);
  const w = canvas.offsetWidth, h = 60;
  const pad = { top: 8, right: 8, bottom: 8, left: 8 };
  const plotW = w - pad.left - pad.right;
  const plotH = h - pad.top - pad.bottom;
  ctx.clearRect(0, 0, w, h);
  const emotions = [
    { key: 'excitement', color: '#ff6b6b' },
    { key: 'tranquility', color: '#4facfe' },
    { key: 'culture_depth', color: '#b197fc' },
  ];
  emotions.forEach(em => {
    ctx.beginPath(); ctx.strokeStyle = em.color; ctx.lineWidth = 2;
    let started = false;
    curve.forEach((pt, i) => {
      const x = pad.left + (i / (curve.length - 1)) * plotW;
      const val = pt[em.key] || 0;
      const y = pad.top + plotH * (1 - val);
      if (!started) { ctx.moveTo(x, y); started = true; } else ctx.lineTo(x, y);
    });
    ctx.stroke();
  });
}

// ── Chat 消息 ──
function addChatMessage(text, type = 'system') {
  const container = document.getElementById('chatMessages');
  const msg = document.createElement('div');
  msg.className = `chat-msg ${type}`;
  msg.innerHTML = `<div class="msg-label">${type === 'system' ? 'CityFlow' : '你'}</div>${escapeHtml(text)}`;
  container.appendChild(msg);
  container.scrollTop = container.scrollHeight;
}

// ═══════════════════════════════════════════════════════════════
// 智能体管线可视化 (9 agents, 4 waves)
// ═══════════════════════════════════════════════════════════════
const AGENT_DEFINITIONS = [
  { id: 'rule_guard',         name: '规则守卫',   icon: '🛡', wave: 1 },
  { id: 'expert_router',      name: '场景路由',   icon: '🧭', wave: 1 },
  { id: 'poi',                name: '景点专家',   icon: '🏛', wave: 2 },
  { id: 'food',               name: '美食专家',   icon: '🍜', wave: 2 },
  { id: 'weather',            name: '天气评估',   icon: '🌤', wave: 2 },
  { id: 'destination',        name: '目的地专家', icon: '📍', wave: 2 },
  { id: 'traffic',            name: '交通专家',   icon: '🚗', wave: 3 },
  { id: 'hotel',              name: '住宿专家',   icon: '🏨', wave: 3 },
  { id: 'local_expert',       name: '本地达人',   icon: '🏘', wave: 3 },
  { id: 'review',             name: '路线审查',   icon: '🔍', wave: 4 },
  { id: 'synthesizer',        name: '路线合成',   icon: '✨', wave: 5 },
];

function initAgentPanel() {
  const diagram = document.getElementById('archDiagram');
  const flow = document.getElementById('agentFlow');

  diagram.innerHTML = '';

  const waves = [
    { label: 'Wave 1 · 路由', agents: ['rule_guard', 'expert_router'], y: 10 },
    { label: 'Wave 2 · 数据', agents: ['poi', 'food', 'weather', 'destination'], y: 75 },
    { label: 'Wave 3 · 深化', agents: ['traffic', 'hotel', 'local_expert'], y: 150 },
    { label: 'Wave 4 · 审查', agents: ['review'], y: 215 },
    { label: 'Wave 5 · 合成', agents: ['synthesizer'], y: 260 },
  ];

  waves.forEach(wave => {
    const label = document.createElement('div');
    label.className = 'arch-wave-label';
    label.style.top = wave.y + 'px';
    label.textContent = wave.label;
    diagram.appendChild(label);

    const totalWidth = 260;
    const nodeWidth = 55;
    const gap = (totalWidth - wave.agents.length * nodeWidth) / (wave.agents.length + 1);

    wave.agents.forEach((agentId, i) => {
      const def = AGENT_DEFINITIONS.find(a => a.id === agentId);
      const node = document.createElement('div');
      node.className = 'arch-node';
      node.id = `arch-${agentId}`;
      node.style.left = (60 + gap + i * (nodeWidth + gap)) + 'px';
      node.style.top = wave.y + 'px';
      node.style.width = nodeWidth + 'px';
      node.textContent = def ? def.icon : '?';
      node.title = def ? def.name : agentId;
      diagram.appendChild(node);
    });
  });

  flow.innerHTML = AGENT_DEFINITIONS.map(def => `
    <div class="agent-step" id="flow-${def.id}">
      <div class="step-icon">${def.icon}</div>
      <span class="step-label">${def.name}</span>
      <span class="step-status">等待中</span>
    </div>
  `).join('');
}

function setAgentState(agentId, agentState) {
  const flowEl = document.getElementById(`flow-${agentId}`);
  const archEl = document.getElementById(`arch-${agentId}`);

  if (flowEl) {
    flowEl.className = `agent-step ${agentState}`;
    const statusEl = flowEl.querySelector('.step-status');
    if (statusEl) {
      const labels = { active: '运行中...', done: '✓ 完成', error: '✗ 失败' };
      statusEl.textContent = labels[agentState] || '等待中';
    }
  }
  if (archEl) {
    archEl.className = `arch-node ${agentState}`;
  }

  const dot = document.getElementById('agentStatusDot');
  if (agentState === 'active') dot.classList.add('active');
}

function resetAgentPanel() {
  AGENT_DEFINITIONS.forEach(def => setAgentState(def.id, ''));
  document.getElementById('agentStatusDot').classList.remove('active');
}

// ── SSE 事件处理 ──
function handleSSE(type, data) {
  switch (type) {
    case 'chat':
      addChatMessage(data.text, 'system');
      break;
    case 'phase':
      document.getElementById('loadingText').textContent = data.message || '处理中...';
      break;
    case 'agent_start':
      setAgentState(data.agent, 'active');
      break;
    case 'agent_result':
      setAgentState(data.agent, 'done');
      break;
    case 'step':
      state.steps.push(data);
      renderSteps(state.steps, state.currentDay);
      if (data.poi && data.poi.lng && data.poi.lat) {
        renderRouteOnMap(state.steps);
      }
      break;
    case 'day_start':
      state.currentDay = data.day;
      state.steps = [];
      break;
    case 'day_end':
      break;
    case 'done':
      state.routeId = data.route_id;
      if (data.full_route) {
        if (data.full_route.days) {
          state.multiRoutes = data.full_route.days;
          state.totalDays = data.full_route.days.length;
          renderDaySwitch(state.totalDays, state.currentDay);
          const firstDay = state.multiRoutes[0];
          if (firstDay) {
            state.steps = firstDay.route || firstDay.steps || [];
            renderSteps(state.steps, 1);
            renderRouteOnMap(state.steps);
          }
        } else {
          state.steps = data.full_route.route || [];
          renderSteps(state.steps, 1);
          renderRouteOnMap(state.steps);
          renderNarrative(data.full_route.narrative);
          renderEmotionCurve(data.full_route.emotion_curve);
        }
      }
      renderStats(state.steps);
      hideLoading();
      state.isPlanning = false;
      document.getElementById('sendBtn').disabled = false;
      addChatMessage('路线规划完成！', 'system');
      break;
    case 'error':
      addChatMessage(data.error || '规划失败', 'system');
      hideLoading();
      state.isPlanning = false;
      document.getElementById('sendBtn').disabled = false;
      break;
  }
}

// ── 提交规划 ──
async function submitPlan() {
  const input = document.getElementById('userInput');
  const text = input.value.trim();
  if (!text || state.isPlanning) return;

  state.isPlanning = true;
  document.getElementById('sendBtn').disabled = true;

  state.steps = [];
  state.multiRoutes = [];
  state.currentDay = 1;
  state.totalDays = 1;
  resetAgentPanel();
  clearRoute();

  document.getElementById('routeSteps').innerHTML = '';
  document.getElementById('statsBar').classList.add('hidden');
  document.getElementById('narrativeSection').classList.add('hidden');
  document.getElementById('emotionSection').classList.add('hidden');
  document.getElementById('daySwitch').innerHTML = '';

  showLoading('正在连接智能体...');
  addChatMessage(text, 'user');

  try {
    const response = await fetch(`${API_BASE}/api/plan`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ user_input: text }),
    });

    if (!response.ok) throw new Error(`HTTP ${response.status}`);

    const reader = response.body.getReader();
    const decoder = new TextDecoder();
    let buffer = '';

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      buffer += decoder.decode(value, { stream: true });
      const lines = buffer.split('\n');
      buffer = lines.pop() || '';
      let eventType = '';
      for (const line of lines) {
        if (line.startsWith('event: ')) {
          eventType = line.slice(7).trim();
        } else if (line.startsWith('data: ')) {
          try {
            const data = JSON.parse(line.slice(6));
            handleSSE(eventType, data);
          } catch (e) {}
        }
      }
    }
  } catch (err) {
    console.error('Plan error:', err);
    addChatMessage('连接失败: ' + err.message, 'system');
    hideLoading();
    state.isPlanning = false;
    document.getElementById('sendBtn').disabled = false;
  }
}

// ── Loading ──
function showLoading(text) {
  document.getElementById('loadingText').textContent = text || '正在规划路线...';
  document.getElementById('loadingOverlay').classList.add('active');
}
function hideLoading() {
  document.getElementById('loadingOverlay').classList.remove('active');
}

// ── 工具函数 ──
function escapeHtml(str) {
  const el = document.createElement('span');
  el.textContent = str || '';
  return el.innerHTML;
}

// ── 初始化 ──
document.addEventListener('DOMContentLoaded', async () => {
  await initMap();
  initAgentPanel();

  document.getElementById('userInput').addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); submitPlan(); }
  });
});
</script>

</body>
</html>
