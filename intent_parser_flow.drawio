<mxfile host="Electron" agent="Claude">
  <diagram name="Intent Parser 流程" id="intent-parser-flow">
    <mxGraphModel dx="2440" dy="2220" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
