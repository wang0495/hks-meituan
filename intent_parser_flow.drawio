          <mxGeometry height="100" width="220" x="350" y="240" as="geometry" />
        </mxCell>
        <mxCell id="merge" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=8;" value="&lt;b&gt;合并 intent&lt;/b&gt;&lt;br&gt;─────────────────&lt;br&gt;time / budget / group&lt;br&gt;preferences / pace&lt;br&gt;hard_constraints&lt;br&gt;&lt;b&gt;demand_vector (7维)&lt;/b&gt;&lt;br&gt;scene_requirements" vertex="1">
